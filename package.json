{
  "name": "re-mplus",
  "type": "module",
  "private": true,
  "author": "Rhythm",
  "license": "MIT",
  "scripts": {
    "build": "tsc --project ./",
    "build:cron": "esbuild src/updater/analyse.ts --bundle --platform=node --outfile=dist/analyse.js",
    "build:public": "esbuild src/browser/main.ts --bundle --minify --outfile=public/main.js",
    "build:static": "tsx src/data/index.ts",
    "dev": "esbuild src/browser/main.ts --bundle --outdir=public --watch --servedir=public",
    "dev:data": "tsx src/updater/analyse.ts public/data.json",
    "start": "serve public",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@rhyster/wow-casc-dbc": "^2.15.5",
    "async": "^3.2.6",
    "jimp": "^1.6.1"
  },
  "devDependencies": {
    "@rhyster/eslint-config": "^2.0.14",
    "@types/async": "^3.2.25",
    "@types/node": "^24.12.4",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.1",
    "serve": "^14.2.6",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.5.0"
}
